        "seed": {
          "description": "随机种子",
          "levels": [0, 1]
        },
        "num_dynamic_obstacles": {
          "description": "动态障碍物数量",
          "levels": [0, 2]
        },
        "sensor_noise": {
          "description": "传感器高斯噪声标准差",
          "levels": [0.0]
        },
        "execution_noise": {
          "description": "执行噪声标准差",
          "levels": [0.0]
        }
      },
      "controlled": {
        "num_bots": [1],
        "max_steps": 1200
      },
      "grid": {
        "algorithms": ["random", "astar", "dstar"],
