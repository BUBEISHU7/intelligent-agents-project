        "num_dynamic_obstacles": [0, 2],
        "sensor_noise": [0.0],
        "execution_noise": [0.0],
        "max_steps": 1200
      }
    },
    "full": {
      "label": "扩展：多机器人×多任务×多种子×动态障碍×噪声",
      "independent_variables": {
        "algorithm": {
          "description": "规划策略",
          "levels": ["random", "astar", "dstar"]
        },
        "num_bots": {
          "description": "机器人数量（协作规模）",
          "levels": [1, 2]
        },
        "num_dirt": {
          "description": "灰尘数量",
          "levels": [50, 100, 150]
