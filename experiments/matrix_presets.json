        "algorithm": {
          "description": "规划策略",
          "levels": ["random", "astar"]
        },
        "num_dirt": {
          "description": "环境中灰尘数量（任务难度代理）",
          "levels": [50]
        },
        "seed": {
          "description": "随机种子（可重复性）",
          "levels": [0]
        },
        "num_dynamic_obstacles": {
          "description": "动态障碍物数量",
          "levels": [0]
        },
        "sensor_noise": {
          "description": "传感器高斯噪声标准差",
          "levels": [0.0]
        },
        "execution_noise": {
          "description": "执行噪声标准差",
          "levels": [0.0]
        }
      },
      "controlled": {
        "num_bots": [1],
        "max_steps": 200
      },
      "grid": {
        "algorithms": ["random", "astar"],
        "num_bots": [1],
        "num_dirt": [50],
        "seeds": [0],
