        "seed": {
          "description": "随机种子",
          "levels": [0, 1]
        }
      },
      "controlled": {
        "num_bots": [2],
        "num_dirt": [100],
        "max_steps": 1200
      },
      "grid": {
        "algorithms": ["astar", "dstar"],
        "num_bots": [2],
        "num_dirt": [100],
        "seeds": [0, 1],
        "num_dynamic_obstacles": [0, 2, 4],
        "sensor_noise": [0.0, 2.0, 5.0],
        "execution_noise": [0.0, 0.3, 0.8],
        "max_steps": 1200
      }
    }
  }
