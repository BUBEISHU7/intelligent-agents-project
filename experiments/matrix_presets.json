      "controlled": {
        "max_steps": 1200
      },
      "grid": {
        "algorithms": ["random", "astar", "dstar"],
        "num_bots": [1, 2],
        "num_dirt": [50, 100, 150],
        "seeds": [0, 1, 2],
        "num_dynamic_obstacles": [0, 2],
        "sensor_noise": [0.0, 2.0],
        "execution_noise": [0.0, 0.3],
        "max_steps": 1200
      }
    },
